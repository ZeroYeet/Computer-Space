  <!-- Footer Bottom -->
  <div class="footer-bottom">
    <div class="container">
      <div class="row">
        <div class="col-md-6">
          <div class="partners-title">ĐƠN VỊ VẬN CHUYỂN</div>
          <div class="partner-logos">
            <span class="logo-placeholder">Giao hàng nhanh</span>
            <span class="logo-placeholder">VNPost</span>
            <span class="logo-placeholder">GHN</span>
            <span class="logo-placeholder">GHTK</span>
            <span class="logo-placeholder">J&T Express</span>
          </div>
        </div>
        <div class="col-md-6">
          <div class="partners-title">CÁCH THỨC THANH TOÁN</div>
