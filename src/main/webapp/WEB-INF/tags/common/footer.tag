            <span class="logo-placeholder">Visa/Master</span>
            <span class="logo-placeholder">JCB</span>
            <span class="logo-placeholder">MoMo</span>
            <span class="logo-placeholder">ZaloPay</span>
            <span class="logo-placeholder">COD</span>
          </div>
        </div>
      </div>
      <div class="row">
        <div class="col-12">
          <div class="partners-title">KẾT NỐI VỚI CHÚNG TÔI</div>
