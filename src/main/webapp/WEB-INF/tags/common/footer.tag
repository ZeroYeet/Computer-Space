          <li><a href="#">Tra cứu bảo hành</a></li>
        </ul>
      </div>
      <div class="col-lg-3 col-md-6 footer-widget">
        <h4>TỔNG ĐÀI HỖ TRỢ (8:00 - 21:00)</h4>
        <div class="hotline-box">
          <div class="hotline-title">Mua hàng & Tư vấn</div>
          <a href="tel:1900123456" class="hotline-number">1900 123 456</a>
        </div>
        <div class="hotline-box" style="margin-top: 10px;">
          <div class="hotline-title">Khiếu nại & Bảo hành</div>
          <a href="tel:1900654321" class="hotline-number">1900 654 321</a>
        </div>
      </div>
    </div>
